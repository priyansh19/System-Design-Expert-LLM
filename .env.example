# Teacher model for synthetic data generation.
# Default: local Ollama model "ornith-nothink:9b" — free, unlimited, and open-weight (no
# vendor ToS restriction on training/publishing a model derived from its outputs, unlike a
# proprietary API). Build it once from any Qwen3-arch chat model with a Modelfile like:
#   FROM <your-local-9b-model>
#   SYSTEM You are a distinguished (staff+) software architect ... /no_think
# then `ollama create ornith-nothink:9b -f Modelfile`.
TEACHER_PROVIDER=ornith
ORNITH_BASE_URL=http://localhost:11434/v1
ORNITH_MODEL=ornith-nothink:9b

# --- DeepSeek (paid fallback teacher if local quality is insufficient) ---
# TEACHER_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Groq (recommended fast/free teacher upgrade from local ornith) ---
# Free tier: no credit card, ~30 RPM / 6K TPM / 1K RPD (console.groq.com). qwen/qwen3-32b is
# Apache-2.0 (no license naming/attribution requirement on the shipped model, unlike Llama
# models) and ~400 tok/s vs ~8 tok/s on local CPU. Verified TEACHER-safe: Groq's Services
# Agreement (Sec 4.2/8.1) has Customer retain all IP in Inputs/Outputs and bars only GROQ's
# own use of them for training -- the sole customer-side restriction (Sec 6.3e) is against
# building a rival inference *platform*, not downstream fine-tuning.
# TEACHER_PROVIDER=groq
GROQ_API_KEY=gsk_your-groq-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=qwen/qwen3-32b

# --- Cerebras (second free teacher stream, run alongside Groq -- NOT a replacement) ---
# Free tier: no credit card, 1M TPD per model / 5 RPM / 30K TPM, token-bucket refill
# (cloud.cerebras.ai). Verified TEACHER-safe: Cerebras ToS states inputs/outputs are
# governed by Third-Party Model Terms and explicitly does NOT grant Cerebras the right to
# use Service Content for training/fine-tuning; independently verified no retention.
# Model note: gemma-4-31b is used here as a deliberate, accepted tradeoff -- Gemma's own
# Terms of Use make any model trained on its outputs a "Model Derivative" bound by Gemma's
# Terms/Prohibited Use Policy. gpt-oss-120b (Apache 2.0, zero downstream encumbrance,
# ~3000 tok/s, larger MoE than Groq's qwen3-32b) is the clean-license alternative if that
# tradeoff isn't wanted -- swap CEREBRAS_MODEL below.
# Run as a second concurrent stream via: --teacher-provider cerebras --sft-out
# data/generated/sft_cerebras.jsonl (separate output file -- two processes must never share
# one sft.jsonl, each round overwrites the whole file so concurrent writers lose updates).
CEREBRAS_API_KEY=csk-your-cerebras-key
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gemma-4-31b

# --- xAI / Grok (fallback teacher; OpenAI-compatible) ---
XAI_API_KEY=xai-your-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-fast

# --- OpenAI (optional; also used as an eval JUDGE, must differ from teacher family) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- NVIDIA API Catalog (build.nvidia.com) — JUDGE-ONLY, free trial key, ~40 req/min,
# 1000 free credits. Judge-only by design: the trial ToS is "limited trial ... internal
# testing and evaluation purposes, not production" and bars redistributing Generated
# Content beyond that (Sections 1.2/1.4/4.2) — fine for scoring our own answers into a
# local report, NOT fine as a teacher whose outputs get trained into the shipped model
# (same ToS category as the Claude CLI risk already fixed). Default model is Llama, not
# Qwen, so it satisfies "judge family != teacher family" against the Qwen3-based ornith.
# JUDGE_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Judge provider for evaluation (MUST be a different family than TEACHER_PROVIDER).
JUDGE_PROVIDER=openai

# --- Base/weaker model for DPO 'rejected' answers (default: local Ollama, no key needed) ---
BASE_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:0.5b

# --- Our own fine-tune, once merged + `ollama create`-d post-training (used by eval/judge.py) ---
FINETUNE_BASE_URL=http://localhost:11434/v1
FINETUNE_MODEL=system-design-expert

# Generation controls
GEN_CONCURRENCY=6
GEN_TEMPERATURE=0.7
