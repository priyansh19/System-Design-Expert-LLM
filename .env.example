# Teacher model for synthetic data generation (OpenAI-compatible endpoint).
# Default provider is DeepSeek (cheap, strong technical reasoning).
TEACHER_PROVIDER=deepseek

# --- DeepSeek (recommended teacher) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- xAI / Grok (fallback teacher; OpenAI-compatible) ---
XAI_API_KEY=xai-your-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-fast

# --- OpenAI (optional; also used as an eval JUDGE, must differ from teacher family) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Judge provider for evaluation (MUST be a different family than TEACHER_PROVIDER).
JUDGE_PROVIDER=openai

# --- Base/weaker model for DPO 'rejected' answers (default: local Ollama, no key needed) ---
BASE_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Generation controls
GEN_CONCURRENCY=6
GEN_TEMPERATURE=0.7
